# Copy to .env and edit. NEVER commit .env.
# Anything not set here uses the safe defaults baked into docker-compose.yml.

# ---- Host ports ----
# Override these (manually or via `make docker-up-auto`) when 3000 / 8000
# are already in use. The auto-picker writes a `.env.ports` file that
# `make docker-up-auto` consumes via --env-file.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# ---- URLs (must match the host ports above) ----
# Browser-facing backend URL (Next.js bakes this into the client bundle at build time).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated origins allowed to call the backend.
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Logging ----
APP_LOG_LEVEL=INFO

# ---- Embeddings ----
APP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Optional LLM extraction (off by default) ----
# Uncomment + set ONE of the API keys below. The service auto-detects
# which provider to use based on which key is present. Set
# LLM_PROVIDER explicitly only if both keys are configured.
# USE_LLM_EXTRACTION=true
# LLM_PROVIDER=openai           # or "anthropic" / "claude_code"
# claude_code option uses your Claude Pro/Max session (no API credits)
# via the `claude` CLI mounted in the backend container. Requires:
#   - Claude Code installed + logged in on the host
#   - docker-compose mounts ~/.claude:/home/app/.claude:ro (already wired)
# LLM_TIMEOUT_SECONDS=30

# --- OpenAI / OpenAI-compatible (vLLM, Ollama, LM Studio, Together…) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_MODEL=claude-haiku-4-5      # or claude-sonnet-4-5 for quality
