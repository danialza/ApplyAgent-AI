# Copy to .env and adjust as needed.
# All variables are optional except OPENAI_API_KEY when LLM extraction is on.

# Persistence / CORS
# APP_DB_URL=sqlite:///./data/app.db
# APP_CORS_ORIGINS=http://localhost:3000
# APP_LOG_LEVEL=INFO
# APP_INDEX_DIR=./data/index

# Embeddings (semantic search)
# APP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional LLM extraction layer (off by default).
# USE_LLM_EXTRACTION=true
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini
# LLM_TIMEOUT_SECONDS=30
